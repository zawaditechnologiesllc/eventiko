# ---------------------------------------------------------------------------
# Eventiko frontend (Next.js on Vercel)
# Copy to .env.local for local development and set these in Vercel for prod.
# ---------------------------------------------------------------------------

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Eventiko backend (Render)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Public site URL (used for SEO/canonical/sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe publishable key (optional on the client; checkout is server driven)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
