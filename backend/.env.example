# ---------------------------------------------------------------------------
# Eventiko backend (Express API on Render)
# Copy to .env for local dev; set these in the Render dashboard for production.
# ---------------------------------------------------------------------------

# Server
PORT=8080
NODE_ENV=development

# Public URL of the Next.js frontend (used for Stripe redirect + CORS)
FRONTEND_URL=http://localhost:3000

# Supabase — service role key (server-side only, NEVER expose to the client)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Secret used to sign the QR ticket tokens (any long random string)
TICKET_SECRET=change-me-to-a-long-random-string

# Email delivery (optional — pick ONE). If none set, emails are logged only.
# Option A: Resend (https://resend.com)
RESEND_API_KEY=
EMAIL_FROM="Eventiko <tickets@eventiko.com>"
# Option B: SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# News aggregation
# Secret to protect the /api/news/refresh cron endpoint (used by Render Cron)
CRON_SECRET=change-me
# Optional API keys to enrich news (RSS works without any keys)
NEWS_API_KEY=
GNEWS_API_KEY=
